---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { resolvePath } from '../utils/navigation';
---

<BaseLayout title="Page Not Found" description="The page you are looking for does not exist.">
  <div class="py-24 md:py-32 flex-grow flex items-center justify-center">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-2xl">
      <div class="text-primary-600 font-bold text-7xl md:text-9xl mb-6">404</div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">Page not found</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-10">
        Sorry, we couldn't find the page you're looking for. It might have been moved or deleted.
      </p>
      <div class="flex justify-center gap-4">
        <Button href={resolvePath('/')} variant="primary" size="lg">Go back home</Button>
        <Button href={resolvePath('/blog/')} variant="outline" size="lg">Read the blog</Button>
      </div>
    </div>
  </div>
</BaseLayout>
