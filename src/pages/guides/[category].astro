---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORY_GUIDES, GENERAL_BUYING_TIPS } from '../../lib/categories';

const rawSlug = Astro.params.category || '';
const slug = rawSlug.toLowerCase();
const categoryKey = Object.keys(CATEGORY_GUIDES).find(k => k.toLowerCase() === slug);

if (!categoryKey) {
  return Astro.redirect('/guides/', 301);
}

const guide = CATEGORY_GUIDES[categoryKey];

const catColors: Record<string, string> = {
  Electronics: 'from-indigo-500 to-purple-600',
  Headphones: 'from-emerald-500 to-teal-600',
  Smartphones: 'from-amber-500 to-orange-600',
  'Smart Home': 'from-cyan-500 to-blue-600',
  'Home & Kitchen': 'from-rose-500 to-pink-600',
  'Fashion & Beauty': 'from-violet-500 to-indigo-600',
  Gaming: 'from-orange-500 to-red-600',
  Books: 'from-teal-500 to-green-600',
};
const gradient = catColors[categoryKey] || 'from-slate-500 to-slate-600';

const catIcons: Record<string, string> = {
  Electronics: '<path d="M9 3a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v1h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h3V3Zm0 1H6a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-3v1a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V4Zm2 0h2V3h-2v1Z"/><rect x="9" y="10" width="6" height="6" rx="1"/>',
  Headphones: '<path d="M4 14a8 8 0 0 1 16 0v2a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h1.8A6 6 0 0 0 5.2 13H7a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-2Z"/><circle cx="6.5" cy="13.5" r="1.5"/><circle cx="17.5" cy="13.5" r="1.5"/>',
  Smartphones: '<rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/>',
  'Smart Home': '<path d="M3 10.5L12 3l9 7.5"/><path d="M5 10v8a2 2 0 0 0 2 2h3v-6h4v6h3a2 2 0 0 0 2-2v-8"/><circle cx="12" cy="15" r="1"/>',
  'Home & Kitchen': '<path d="M4 5h16v2a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4V5Z"/><path d="M8 3h8v2H8V3Z"/><path d="M12 11v10"/><path d="M8 21h8"/>',
  'Fashion & Beauty': '<path d="M7 4.5a4 4 0 0 1 4 0l1 .5 1-.5a4 4 0 0 1 4 0v.5A4 4 0 0 1 17 8H7a4 4 0 0 1 0-3.5Z"/><path d="M12 8v4"/><path d="M8 18a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4H8v-4Z"/>',
  Gaming: '<path d="M6 12H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-2"/><path d="M6 12v7a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-7"/><circle cx="9" cy="9" r="1"/><circle cx="15" cy="9" r="1"/>',
  Books: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H6.5a1.5 1.5 0 0 0 0 3H19"/><path d="M4 19.5V6"/>',
};
const iconSvg = catIcons[categoryKey] || '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a2.5 2.5 0 0 1 0-5H20"/>';
---

<BaseLayout
  title={`${categoryKey} Buying Guide`}
  description={`Expert ${categoryKey.toLowerCase()} buying guide — tips, advice, and recommendations to help you choose the best products on Amazon.in`}
>
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <a href="/guides/" class="inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 hover:underline mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        Back to Guides
      </a>

      <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${gradient} flex items-center justify-center mb-6`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconSvg}>
      </div>

      <h1 class="font-heading text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">{guide.guideTitle}</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed">{guide.guideIntro}</p>

      <div class="glass-panel rounded-2xl p-8 mb-10">
        <h2 class="font-heading text-xl font-bold text-slate-900 dark:text-white mb-6">Key Considerations</h2>
        <div class="space-y-6">
          {guide.tips.map((tip, i) => (
            <div class="flex gap-4">
              <div class={`w-8 h-8 rounded-lg bg-gradient-to-br ${gradient} flex items-center justify-center shrink-0 mt-0.5`}>
                <span class="text-white text-sm font-bold">{i + 1}</span>
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed pt-1.5">{tip}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="glass-panel rounded-2xl p-8 mb-10">
        <h2 class="font-heading text-xl font-bold text-slate-900 dark:text-white mb-4">Budget Advice</h2>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{guide.budgetAdvice}</p>
      </div>

      <div class="glass-panel rounded-2xl p-8">
        <h2 class="font-heading text-xl font-bold text-slate-900 dark:text-white mb-6">More Shopping Tips</h2>
        <ul class="space-y-4">
          {GENERAL_BUYING_TIPS.map(tip => (
            <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              <svg class="w-5 h-5 mt-0.5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-10 text-center">
        <a
          href={`/products/?category=${encodeURIComponent(categoryKey)}`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-primary-600 text-white rounded-xl text-lg font-semibold hover:bg-primary-700 transition-all shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40"
        >
          Browse {categoryKey} Deals
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
