---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORY_GUIDES, GENERAL_BUYING_TIPS } from '../../lib/categories';

const categories = Object.entries(CATEGORY_GUIDES);
const catColors: Record<string, string> = {
  Electronics: 'from-indigo-500 to-purple-600',
  Headphones: 'from-emerald-500 to-teal-600',
  Smartphones: 'from-amber-500 to-orange-600',
  'Smart Home': 'from-cyan-500 to-blue-600',
  'Home & Kitchen': 'from-rose-500 to-pink-600',
  'Fashion & Beauty': 'from-violet-500 to-indigo-600',
  Gaming: 'from-orange-500 to-red-600',
  Books: 'from-teal-500 to-green-600',
};
---

<BaseLayout title="Buying Guides" description="Expert buying guides and tips to help you make smart purchase decisions on Amazon.in">
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Buying <span class="text-gradient">Guides</span>
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          Expert advice and practical tips to help you make smarter purchase decisions. 
          Our guides cover everything from electronics to home essentials.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {categories.map(([category, guide]) => {
          const gradient = catColors[category] || 'from-slate-500 to-slate-600';
          return (
            <a
              href={`/guides/${encodeURIComponent(category.toLowerCase())}/`}
              class="group block glass-panel rounded-2xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            >
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${gradient} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
              </div>
              <h2 class="font-heading text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{category} Guide</h2>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{guide.description}</p>
              <div class="mt-4 flex items-center gap-1 text-sm font-medium text-primary-600 dark:text-primary-400 group-hover:underline">
                Read Guide
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </a>
          );
        })}
      </div>

      <div class="mt-20 max-w-3xl mx-auto">
        <div class="glass-panel rounded-2xl p-8">
          <h2 class="font-heading text-2xl font-bold text-slate-900 dark:text-white mb-6">General Shopping Tips</h2>
          <ul class="space-y-4">
            {GENERAL_BUYING_TIPS.map(tip => (
              <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                <svg class="w-5 h-5 mt-0.5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
