---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getProducts, ensureAffiliateTag } from '../../lib/data';
import { CATEGORY_GUIDES } from '../../lib/categories';
import { SITE_URL } from '../../config';

const { id } = Astro.params;
const db = env.DB;
const products = await getProducts(db);
const product = products.find(p => p.id === id);
if (!product) {
  return Astro.redirect('/products/');
}

const related = products
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 6);

const images = [product.imageUrl, product.imageUrl2, product.imageUrl3].filter(Boolean);

function getRatingPercent(rating: string): number {
  const match = rating.match(/([\d.]+)/);
  if (match) {
    return (parseFloat(match[1]) / 5) * 100;
  }
  return 0;
}

const productURL = `${SITE_URL.replace(/\/$/, '')}/p/${product.id}/`;

const ogDesc = product.category ? `${product.title} — ${product.category}` : product.title;

function resizeImage(url: string | undefined): string | undefined {
  if (!url) return undefined;
  return url.replace(/\._(S[LX]\d+|SL\d+)_/i, '._SL500_');
}

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description || product.title,
  image: images.length > 0 ? images : undefined,
  url: productURL,
  ...(product.rating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: product.rating.match(/([\d.]+)/)?.[0] || undefined,
      bestRating: '5',
    },
  } : {}),
};
---

<BaseLayout title={product.title} description={ogDesc} image={resizeImage(product.imageUrl)} imageWidth="500" imageHeight="500">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <section class="py-8 md:py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: product.category || 'Products', url: `/products/${product.category ? `?category=${encodeURIComponent(product.category)}` : ''}` },
        { label: product.title },
      ]} />

      {product.category && CATEGORY_GUIDES[product.category] && (
        <div class="mb-6 p-3 rounded-xl bg-primary-50 dark:bg-primary-950/30 border border-primary-200 dark:border-primary-900/50">
          <p class="text-xs text-primary-700 dark:text-primary-400">
            💡 <a href={`/guides/${encodeURIComponent(product.category.toLowerCase())}/`} class="font-medium underline hover:no-underline">Read our {product.category} Buying Guide</a> for expert tips before you buy.
          </p>
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-3 space-y-8">
          <!-- Image Gallery -->
          {images.length > 0 ? (
            <div>
              <div id="image-container" class="relative glass-panel rounded-2xl p-3 sm:p-4 mb-4 cursor-pointer">
                <a
                  href={`https://wa.me/?text=${encodeURIComponent(`Check this deal: ${product.title} - ${productURL}`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="absolute top-5 right-5 z-10 w-10 h-10 rounded-full bg-green-500 text-white flex items-center justify-center shadow-lg hover:bg-green-600 hover:scale-110 transition-all"
                  aria-label="Share on WhatsApp"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                </a>
                <img id="main-image" src={images[0]} alt={product.title} fetchpriority="high" class="w-full object-contain max-h-[450px] transition-opacity duration-300" />
              </div>
              {images.length > 1 && (
                <div class="flex gap-3 justify-center">
                  {images.map((img, i) => (
                    <button
                      data-img={img}
                      class="image-thumb w-16 h-16 rounded-xl border-2 overflow-hidden transition-all duration-200 hover:border-primary-400 {i === 0 ? 'border-primary-500' : 'border-slate-200 dark:border-slate-700'}"
                    >
                      <img src={img} alt={`${product.title} view ${i + 1}`} class="w-full h-full object-contain bg-white dark:bg-slate-800" loading="lazy" />
                    </button>
                  ))}
                </div>
              )}
            </div>
          ) : (
            <div class="glass-panel rounded-2xl p-3 sm:p-4 flex items-center justify-center aspect-[4/3] max-h-[400px]">
              <div class="w-full h-full flex items-center justify-center text-slate-300 dark:text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              </div>
            </div>
          )}

          <!-- Product Info -->
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-300 mb-4">
              {product.category}
            </span>

            <h1 class="font-heading text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-4">
              {product.title}
            </h1>

            {product.rating && (
              <div class="flex items-center gap-3 mb-4">
                <div class="relative w-24 h-4">
                  <div class="absolute inset-0 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
                  <div class="absolute inset-0 bg-yellow-400 rounded-full" style={`width: ${getRatingPercent(product.rating)}%`}></div>
                </div>
                <span class="text-sm text-slate-600 dark:text-slate-400">{product.rating}</span>
              </div>
            )}
          </div>

          <!-- Description -->
          {product.description && (
            <div>
              <h2 class="font-heading text-xl font-semibold text-slate-900 dark:text-white mb-3">About This Product</h2>
              <div class="text-slate-600 dark:text-slate-400 leading-relaxed whitespace-pre-line">{product.description}</div>
            </div>
          )}

          <!-- Why We Recommend (Review) -->
          {product.review && (
            <div class="rounded-xl border border-primary-200 bg-primary-50 px-5 py-4 dark:border-primary-900/50 dark:bg-primary-950/30">
              <p class="text-sm font-semibold text-primary-800 dark:text-primary-300 mb-2 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>
                Why We Recommend This
              </p>
              <div class="text-sm text-primary-700 dark:text-primary-400 leading-relaxed whitespace-pre-wrap">{product.review}</div>
            </div>
          )}

          <!-- Coupon -->
          {product.coupon && (
            <div class="flex items-start gap-3 rounded-xl border border-green-200 bg-green-50 px-4 py-3 dark:border-green-900/50 dark:bg-green-950/30">
              <svg class="w-5 h-5 mt-0.5 text-green-600 dark:text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>
              <div>
                <p class="text-sm font-semibold text-green-800 dark:text-green-300">Coupon / Offer Available</p>
                <p class="text-sm text-green-700 dark:text-green-400 mt-0.5">{product.coupon}</p>
              </div>
            </div>
          )}

          <!-- Buy Button -->
          {product.affiliateUrl ? (
            <div class="pt-2">
              <a
                href={ensureAffiliateTag(product.affiliateUrl)}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="inline-flex items-center justify-center gap-3 w-full sm:w-auto px-8 py-4 bg-primary-600 text-white rounded-xl text-lg font-semibold hover:bg-primary-700 transition-all shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Check out Here
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
              </a>
              <p class="mt-3 text-xs text-slate-400">As an Amazon Associate I earn from qualifying purchases.</p>
            </div>
          ) : (
            <p class="text-sm text-slate-500 dark:text-slate-400 italic">Affiliate link not yet available. Check back later.</p>
          )}
        </div>

        <!-- Right Sidebar: Related Products -->
        {related.length > 0 && (
          <aside class="lg:col-span-1">
            <div class="lg:sticky lg:top-24">
              <h3 class="font-heading font-semibold text-sm uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-4">Related Products</h3>
              <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-1 gap-3">
                {related.map(r => (
                  <a
                    href={`/p/${r.id}/`}
                    class="group flex items-start gap-3 p-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-900/50 transition-colors"
                  >
                    {r.imageUrl ? (
                      <img src={r.imageUrl} alt={r.title} class="w-14 h-14 rounded-lg object-contain bg-slate-100 dark:bg-slate-800 flex-shrink-0" loading="lazy" />
                    ) : (
                      <div class="w-14 h-14 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-300 dark:text-slate-600 flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                      </div>
                    )}
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-slate-700 dark:text-slate-300 line-clamp-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{r.title}</p>
                      {r.rating && (
                        <p class="text-xs text-slate-400 mt-0.5">{r.rating}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </aside>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<div id="lightbox" class="fixed inset-0 z-50 bg-black/80 hidden items-center justify-center p-4 cursor-pointer" onclick="closeLightbox()">
  <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain cursor-default" onclick="event.stopPropagation()" />
  <button class="absolute top-4 right-4 w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white text-2xl transition-colors" onclick="closeLightbox()">&times;</button>
</div>

<script>
  document.addEventListener('astro:page-load', function() {
    var thumbs = document.querySelectorAll('.image-thumb');
    var main = document.getElementById('main-image');
    var container = document.getElementById('image-container');
    var lightbox = document.getElementById('lightbox');
    var lightboxImg = document.getElementById('lightbox-img');

    function openLightbox(src) {
      if (lightbox && lightboxImg && src) {
        lightboxImg.src = src;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
      }
    }

    window.closeLightbox = function() {
      if (lightbox) {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
      }
    };

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeLightbox();
    });

    if (main && container) {
      container.addEventListener('click', function() {
        openLightbox(main.src);
      });
    }

    if (thumbs.length > 0 && main) {
      thumbs.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var img = this.getAttribute('data-img');
          if (img) main.src = img;
          thumbs.forEach(function(t) {
            t.classList.remove('border-primary-500');
            t.classList.add('border-slate-200', 'dark:border-slate-700');
          });
          this.classList.add('border-primary-500');
          this.classList.remove('border-slate-200', 'dark:border-slate-700');
        });
      });
    }
  });
</script>