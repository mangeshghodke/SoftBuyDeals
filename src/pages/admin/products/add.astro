---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import { getCsrfToken } from '../../../lib/session';

const secret = env.SESSION_SECRET as string;
const sessionToken = Astro.cookies.get('session')?.value || '';
const csrfToken = sessionToken ? getCsrfToken(sessionToken, secret) : '';
const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Add Product" robots="noindex, nofollow">
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="mb-8">
        <a href="/admin/dashboard/" class="text-sm text-primary-600 dark:text-primary-400 hover:underline mb-2 inline-block">&larr; Back to Dashboard</a>
        <h1 class="font-heading text-3xl font-bold text-slate-900 dark:text-white">Add Product</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Fill in the product details below.</p>
      </div>

      {error && (
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-900/60 dark:bg-red-950/40 dark:text-red-300">
          {error}
        </div>
      )}

      <form method="POST" action="/api/products/" class="glass-panel rounded-2xl p-6 sm:p-8 space-y-6">
        <input type="hidden" name="_csrf" value={csrfToken} />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <label for="title" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Product Title</label>
            <input id="title" name="title" type="text" required
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="Product Name"
            />
          </div>

          <div>
            <label for="price" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Price</label>
            <input id="price" name="price" type="text" required
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="₹1,299"
            />
          </div>

          <div>
            <label for="originalPrice" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Original Price (M.R.P.)</label>
            <input id="originalPrice" name="originalPrice" type="text"
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="₹2,499"
            />
          </div>

          <div class="md:col-span-2">
            <label for="coupon" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Coupon / Offer (optional)</label>
            <input id="coupon" name="coupon" type="text"
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="e.g. Use code SAVE50 for 50% off"
            />
          </div>

          <div>
            <label for="rating" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Rating</label>
            <div class="flex items-center gap-2">
              <input id="rating" name="rating" type="number" min="0" max="5" step="0.1"
                class="w-24 rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
                placeholder="4.5"
              />
              <span class="text-sm text-slate-500 dark:text-slate-400">out of 5.0</span>
            </div>
          </div>

          <div>
            <label for="category" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Category</label>
            <input id="category" name="category" type="text"
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="Electronics"
            />
          </div>

          <div class="md:col-span-2">
            <label for="imageUrl" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Image URL</label>
            <div class="flex gap-4 items-start">
              <div class="flex-1">
                <input id="imageUrl" name="imageUrl" type="url"
                  class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
                  placeholder="https://m.media-amazon.com/images/..."
                />
              </div>
              <div id="image-preview" class="w-20 h-20 rounded-xl bg-slate-100 dark:bg-slate-800 flex-shrink-0 overflow-hidden hidden">
                <img id="preview-img" class="w-full h-full object-cover" alt="Preview" />
              </div>
            </div>
          </div>

          <div class="md:col-span-2">
            <label for="amazonUrl" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Amazon Product URL</label>
            <input id="amazonUrl" name="amazonUrl" type="url"
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="https://www.amazon.in/dp/..."
            />
          </div>

          <div class="md:col-span-2">
            <label for="affiliateUrl" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Affiliate URL (with tag)</label>
            <input id="affiliateUrl" name="affiliateUrl" type="url"
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="https://www.amazon.in/dp/...?tag=your-tag-21"
            />
          </div>

          <div class="md:col-span-2">
            <label for="review" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Original Review</label>
            <div class="flex gap-3 items-start">
              <textarea id="review" name="review" rows="3"
                class="flex-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white resize-none"
                placeholder="Why we recommend this product — share your genuine opinion, what makes it worth buying, who it's for..."
              ></textarea>
              <button type="button" id="generate-review" class="shrink-0 px-4 py-3 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 rounded-xl text-sm font-medium hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors">
                Generate
              </button>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
          <Button type="submit" variant="primary">Save Product</Button>
          <a href="/admin/dashboard/" class="px-4 py-2.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Cancel</a>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  function showImagePreview(url) {
    const container = document.getElementById('image-preview');
    const img = document.getElementById('preview-img');
    if (url) {
      container.classList.remove('hidden');
      img.src = url;
    } else {
      container.classList.add('hidden');
    }
  }

  document.getElementById('imageUrl').addEventListener('input', (e) => {
    showImagePreview(e.target.value);
  });

  document.getElementById('generate-review')?.addEventListener('click', async function() {
    var title = document.getElementById('title').value.trim();
    var category = document.getElementById('category').value.trim();
    if (!title) { alert('Please fill in the product title first.'); return; }
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Generating...';
    try {
      var res = await fetch('/api/generate-review', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: title, category: category || 'General' })
      });
      var data = await res.json();
      if (data.review) {
        document.getElementById('review').value = data.review;
      } else {
        alert('Failed to generate review. Please try again.');
      }
    } catch (e) {
      alert('Network error. Please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Generate';
    }
  });
</script>
