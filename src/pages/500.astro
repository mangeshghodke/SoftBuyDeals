---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Server Error" description="Something went wrong on our end.">
  <div class="py-24 md:py-32 flex-grow flex items-center justify-center">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-2xl">
      <div class="text-red-500 font-bold text-7xl md:text-9xl mb-6">500</div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">Server error</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-10">
        Something went wrong on our end. Please try again later or contact support if the issue persists.
      </p>
      <div class="flex justify-center gap-4">
        <Button href="/" variant="primary" size="lg">Go back home</Button>
        <Button href="/contact/" variant="outline" size="lg">Contact support</Button>
      </div>
    </div>
  </div>
</BaseLayout>
