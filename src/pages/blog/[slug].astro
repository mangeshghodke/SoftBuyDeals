---
import { getCollection, render, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import Callout from '../../components/mdx/Callout.astro';
import { resolvePath } from '../../utils/navigation';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Resolve the author reference
const author = await getEntry(entry.data.author);
const authorName = author?.data.name ?? 'Zenix Author';
const authorRole = author?.data.role ?? 'Contributor';
const authorAvatar = author?.data.avatar;
const authorInitials = authorName
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0])
  .join('')
  .toUpperCase();

// Related posts logic
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== entry.id) // Exclude current post
  .map(p => {
    const sharedTags = p.data.tags.filter(tag => entry.data.tags.includes(tag));
    return { ...p, sharedCount: sharedTags.length };
  })
  .filter(p => p.sharedCount > 0)
  .sort((a, b) => b.sharedCount - a.sharedCount || b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Register custom MDX components here
const mdxComponents = {
  Callout,
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  type="article"
  publishedDate={entry.data.pubDate}
  modifiedDate={entry.data.updatedDate ?? entry.data.pubDate}
  author={authorName}
>
  <article class="py-24 md:py-32 bg-white dark:bg-[#09090b] relative overflow-hidden">
    
    <!-- Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-primary-500/10 dark:bg-primary-500/5 rounded-full blur-[100px] mix-blend-multiply dark:mix-blend-screen pointer-events-none -z-10"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      
      <!-- Header Section -->
      <div class="mb-16 text-center max-w-4xl mx-auto reveal-on-scroll">
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 mb-6 text-sm font-medium leading-6 text-slate-500 dark:text-slate-400">
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-700"></span>
          <a href={author?.data.twitter} class="min-w-0 text-slate-900 dark:text-slate-300 hover:text-primary-600 dark:hover:text-primary-400 inline-flex items-center gap-2 transition-colors">
              <span class="relative inline-flex h-6 w-6 shrink-0 items-center justify-center overflow-hidden rounded-full bg-primary-100 text-[10px] font-bold text-primary-700 ring-1 ring-primary-200 dark:bg-primary-900/40 dark:text-primary-300 dark:ring-primary-800">
                <span>{authorInitials}</span>
                {authorAvatar && (
                <Image src={authorAvatar} alt={`${authorName} avatar`} width={24} height={24} class="absolute inset-0 h-full w-full rounded-full object-cover" loading="lazy" />
              )}
            </span>
            <span class="leading-6">{authorName}</span>
          </a>
        </div>
        
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-extrabold text-slate-900 dark:text-white mb-8 leading-tight tracking-tight">
          {entry.data.title}
        </h1>
        
        <div class="flex flex-wrap justify-center gap-2">
          {entry.data.tags.map(tag => (
            <Badge variant="neutral">{tag}</Badge>
          ))}
        </div>
      </div>

      <div class="border-t border-slate-200 dark:border-slate-800 my-16"></div>

      <!-- Main Layout Grid (TOC + Content) -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_minmax(auto,700px)_1fr] gap-12 items-start reveal-on-scroll" style="transition-delay: 100ms;">
        
        <!-- Left Sidebar (Social Share / Meta - Placeholder for now) -->
        <div class="hidden lg:block sticky top-24 self-start">
           <a href={resolvePath('/blog/')} class="text-sm font-bold text-slate-500 dark:text-slate-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors inline-flex items-center gap-2 mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to overview
          </a>

          <div class="space-y-6">
            <div class="p-6 glass-panel rounded-2xl">
              <h4 class="text-xs font-bold font-heading text-slate-900 dark:text-white uppercase tracking-widest mb-5">About Author</h4>
              <div class="flex items-start gap-3 mb-4">
                <span class="relative inline-flex h-11 w-11 shrink-0 items-center justify-center overflow-hidden rounded-full bg-primary-100 text-sm font-bold text-primary-700 ring-1 ring-primary-200 dark:bg-primary-900/40 dark:text-primary-300 dark:ring-primary-800">
                  <span>{authorInitials}</span>
                  {authorAvatar && (
                    <Image src={authorAvatar} alt={`${authorName} avatar`} width={44} height={44} class="absolute inset-0 h-full w-full rounded-full object-cover" loading="lazy" />
                  )}
                </span>
                <div class="min-w-0 pt-0.5">
                  <div class="text-sm font-bold leading-snug text-slate-900 dark:text-white break-words">{authorName}</div>
                  <div class="mt-0.5 text-xs leading-snug text-slate-500 dark:text-slate-400">{authorRole}</div>
                </div>
              </div>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
                {author?.data.bio}
              </p>
            </div>
          </div>
        </div>

        <!-- Markdown Content -->
        <div class="prose prose-lg dark:prose-invert prose-slate max-w-none w-full
          prose-headings:font-heading prose-headings:font-bold prose-headings:tracking-tight
          prose-a:text-primary-600 dark:prose-a:text-primary-400 hover:prose-a:text-primary-500
          prose-img:rounded-2xl prose-img:shadow-xl
          prose-pre:bg-slate-900 dark:prose-pre:bg-[#111116] prose-pre:border prose-pre:border-slate-800 prose-pre:rounded-xl">
          <Content components={mdxComponents} />
        </div>

        <!-- Right Sidebar (Table of Contents) -->
        <TableOfContents headings={headings} />

      </div>

      <!-- Related Posts Section -->
      {relatedPosts.length > 0 && (
        <div class="mt-32 pt-16 border-t border-slate-200 dark:border-slate-800 reveal-on-scroll">
          <h3 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-8">Related Articles</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map(post => (
              <a href={resolvePath(`/blog/${post.id}`)} class="group block">
                <div class="p-6 rounded-2xl glass-panel hover-glow transition-all">
                  <time class="text-xs text-slate-500 mb-2 block">{post.data.pubDate.toLocaleDateString()}</time>
                  <h4 class="text-lg font-bold text-slate-900 dark:text-white group-hover:text-primary-600 transition-colors mb-2">{post.data.title}</h4>
                  <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
