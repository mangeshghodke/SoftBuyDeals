---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProducts } from '../../lib/data';

const PER_PAGE = 12;

const db = env.DB;
const allProducts = await getProducts(db);
const categoryNames = [...new Set(allProducts.map(p => p.category))];
const catColors: Record<string, string> = {
  'indigo': 'rgba(99,102,241,0.15)',
  'emerald': 'rgba(16,185,129,0.15)',
  'amber': 'rgba(245,158,11,0.15)',
  'rose': 'rgba(244,63,94,0.15)',
  'cyan': 'rgba(6,182,212,0.15)',
  'violet': 'rgba(139,92,246,0.15)',
  'orange': 'rgba(249,115,22,0.15)',
  'teal': 'rgba(20,184,166,0.15)',
  'pink': 'rgba(236,72,153,0.15)',
  'blue': 'rgba(59,130,246,0.15)',
};
const colorKeys = Object.keys(catColors);
const selectedCategory = Astro.url.searchParams.get('category');
const filtered = selectedCategory
  ? allProducts.filter(p => p.category === selectedCategory)
  : allProducts;
const totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
const currentPage = Math.min(totalPages, Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10) || 1));
const products = filtered.slice((currentPage - 1) * PER_PAGE, currentPage * PER_PAGE);

function pageUrl(page: number): string {
  const params = new URLSearchParams();
  if (selectedCategory) params.set('category', selectedCategory);
  if (page > 1) params.set('page', String(page));
  const qs = params.toString();
  return qs ? `/products/?${qs}` : '/products/';
}

function pageRange(): (number | '...')[] {
  const range: (number | '...')[] = [];
  if (totalPages <= 7) {
    for (let i = 1; i <= totalPages; i++) range.push(i);
    return range;
  }
  range.push(1);
  if (currentPage > 3) range.push('...');
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(totalPages - 1, currentPage + 1);
  for (let i = start; i <= end; i++) range.push(i);
  if (currentPage < totalPages - 2) range.push('...');
  range.push(totalPages);
  return range;
}
---

<BaseLayout title="Products" description="Browse our curated collection of best deals on Amazon.in">
  <section class="py-8 md:py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-4">
          Best Deals on <span class="text-gradient">Amazon.in</span>
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          Curated products with the best prices, handpicked just for you. Click & buy directly from Amazon.in.
        </p>
      </div>

      {categoryNames.length > 1 && (
        <div class="mb-10">
          <h2 class="font-heading text-xl font-bold text-slate-900 dark:text-white mb-4">Categories</h2>
          <div class="relative" id="cat-scroll-wrap">
            <div id="cat-scroll" class="flex gap-2 overflow-x-auto pb-3 scrollbar-thin" style="-webkit-overflow-scrolling:touch">
              <a
                href="/products/"
                class={`shrink-0 rounded-xl px-4 py-2 text-sm font-medium border transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md ${!selectedCategory ? 'bg-primary-600 text-white border-primary-600 shadow-sm' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-700 hover:bg-slate-200 dark:hover:bg-slate-700'}`}
              >All</a>
              {categoryNames.map((cat, i) => {
                const active = selectedCategory === cat;
                const color = catColors[colorKeys[i % colorKeys.length]];
                return <a
                  href={`/products/?category=${encodeURIComponent(cat)}`}
                  class={`shrink-0 rounded-xl px-4 py-2 text-sm font-medium border transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md ${active ? 'shadow-sm' : ''}`}
                  style={active ? `background:${color.replace('0.15','0.35')};border-color:${color.replace('0.15','0.6')};color:#1e293b` : `background:${color};border-color:${color.replace('0.15','0.3')};color:#475569`}
                >{cat}</a>;
              })}
            </div>
            <button id="cat-scroll-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 w-8 h-8 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-md flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors z-10" aria-label="Previous">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button id="cat-scroll-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 w-8 h-8 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-md flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors z-10" aria-label="Next">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      )}

      {products.length === 0 ? (
        <div class="text-center py-20">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto mb-6 text-slate-300 dark:text-slate-600">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <h2 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">No products yet</h2>
          <p class="text-slate-500 dark:text-slate-400">Check back soon for amazing deals!</p>
        </div>
      ) : (
        <>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
          {products.map(product => (
            <ProductCard product={product} />
          ))}
        </div>
        {totalPages > 1 && (
          <nav class="flex items-center justify-center gap-2 mt-10">
            {currentPage > 1 && (
              <a href={pageUrl(currentPage - 1)} class="px-3 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                &laquo; Prev
              </a>
            )}
            {pageRange().map((p) =>
              p === '...' ? (
                <span class="px-2 py-2 text-sm text-slate-400">...</span>
              ) : (
                <a
                  href={pageUrl(p)}
                  class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${p === currentPage ? 'bg-primary-600 text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'}`}
                >
                  {p}
                </a>
              )
            )}
            {currentPage < totalPages && (
              <a href={pageUrl(currentPage + 1)} class="px-3 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                Next &raquo;
              </a>
            )}
          </nav>
        )}
        </>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  (function() {
    var scroll = document.getElementById('cat-scroll');
    if (!scroll) return;
    var prev = document.getElementById('cat-scroll-prev');
    var next = document.getElementById('cat-scroll-next');
    function update() {
      if (!prev || !next) return;
      var atStart = scroll.scrollLeft <= 10;
      var atEnd = scroll.scrollLeft + scroll.clientWidth >= scroll.scrollWidth - 10;
      prev.style.display = atStart && scroll.scrollWidth <= scroll.clientWidth ? 'none' : '';
      prev.style.opacity = atStart ? '0.3' : '1';
      next.style.display = atEnd && scroll.scrollWidth <= scroll.clientWidth ? 'none' : '';
      next.style.opacity = atEnd ? '0.3' : '1';
    }
    if (prev) prev.addEventListener('click', function() {
      scroll.scrollBy({ left: -scroll.clientWidth * 0.7, behavior: 'smooth' });
    });
    if (next) next.addEventListener('click', function() {
      scroll.scrollBy({ left: scroll.clientWidth * 0.7, behavior: 'smooth' });
    });
    scroll.addEventListener('scroll', update);
    update();
  })();
</script>

