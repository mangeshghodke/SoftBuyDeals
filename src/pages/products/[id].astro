---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProducts, getPriceHistory } from '../../lib/data';
import { SITE_URL } from '../../config';
import { validateSession } from '../../lib/session';

const { id } = Astro.params;
const db = env.DB;
const products = await getProducts(db);
const product = products.find(p => p.id === id);
if (!product) {
  return Astro.redirect('/products/');
}

const priceHistory = await getPriceHistory(db, id);
const isAdmin = Astro.cookies.has('session') && validateSession(Astro.cookies.get('session')!.value, env.SESSION_SECRET as string);

interface ChartPoint { x: number; y: number; price: number; date: string; }
let chartPoints: ChartPoint[] = [];
let chartMin = 0; let chartMax = 0; let chartRange = 1; let chartPad = 0;
if (priceHistory.length > 1) {
  const prices = priceHistory.map(p => parseFloat(p.price.replace(/[₹,]/g, '')));
  chartMin = Math.min(...prices);
  chartMax = Math.max(...prices);
  chartRange = chartMax - chartMin || 1;
  chartPad = chartRange * 0.1;
  chartPoints = priceHistory.map((p, i) => {
    const x = 50 + (i / (priceHistory.length - 1)) * 500;
    const y = 180 - ((parseFloat(p.price.replace(/[₹,]/g, '')) - (chartMin - chartPad)) / (chartRange + chartPad * 2)) * 160;
    const d = new Date(p.createdAt);
    return { x, y, price: parseFloat(p.price.replace(/[₹,]/g, '')), date: `${d.getDate()}/${d.getMonth() + 1}` };
  });
}
const chartDateLabels = chartPoints.map((p, i, a) =>
  i % Math.ceil(a.length / 5) === 0 || i === a.length - 1 ? p.date : ''
);

function getRatingPercent(rating: string): number {
  const match = rating.match(/([\d.]+)/);
  if (match) {
    return (parseFloat(match[1]) / 5) * 100;
  }
  return 0;
}

const productURL = `${SITE_URL.replace(/\/$/, '')}/products/${product.id}/`;

const ogPrice = product.price?.trim() || '';
const ogOriginal = product.originalPrice?.trim() || '';
let ogSavings = '';
if (ogPrice && ogOriginal) {
  const curr = parseFloat(ogPrice.replace(/[₹,]/g, ''));
  const orig = parseFloat(ogOriginal.replace(/[₹,]/g, ''));
  if (curr && orig && orig > curr) {
    const pct = Math.round((1 - curr / orig) * 100);
    ogSavings = ` — Save ${pct}%!`;
  }
}
const ogCategory = product.category ? ` [${product.category}]` : '';
const ogDesc = `${ogPrice}${ogOriginal ? ` (was ${ogOriginal})` : ''}${ogSavings}${ogCategory}`;

function resizeImage(url: string | undefined): string | undefined {
  if (!url) return undefined;
  return url.replace(/\._(S[LX]\d+|SL\d+)_/i, '._SL500_');
}

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description?.slice(0, 500) || undefined,
  image: product.imageUrl || undefined,
  url: productURL,
  offers: {
    '@type': 'Offer',
    price: product.price.replace(/[₹,]/g, ''),
    priceCurrency: 'INR',
    url: product.affiliateUrl || productURL,
    availability: 'https://schema.org/InStock',
  },
  ...(product.rating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: product.rating.match(/([\d.]+)/)?.[0] || undefined,
      bestRating: '5',
    },
  } : {}),
};
---

<BaseLayout title={product.title} description={ogDesc} image={resizeImage(product.imageUrl)} imageWidth="500" imageHeight="500">
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <section class="py-8 md:py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <a href="/products/" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">&larr; Back to Products</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <div class="glass-panel rounded-2xl p-6 sm:p-8 flex items-center justify-center aspect-square">
          {product.imageUrl ? (
            <img src={product.imageUrl} alt={product.title} fetchpriority="high" class="w-full h-full object-contain max-h-[450px]" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-slate-300 dark:text-slate-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="96" height="96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          )}
        </div>

        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-300 mb-4">
            {product.category}
          </span>

          <h1 class="font-heading text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mb-4">
            {product.title}
          </h1>

          {product.rating && (
            <div class="flex items-center gap-3 mb-4">
              <div class="relative w-24 h-4">
                <div class="absolute inset-0 bg-slate-200 dark:bg-slate-700 rounded-full"></div>
                <div class="absolute inset-0 bg-yellow-400 rounded-full" style={`width: ${getRatingPercent(product.rating)}%`}></div>
              </div>
              <span class="text-sm text-slate-600 dark:text-slate-400">{product.rating}</span>
            </div>
          )}

          <div class="flex items-baseline gap-3 mb-6">
            <span class="text-3xl font-bold text-slate-900 dark:text-white">{product.price}</span>
            {product.originalPrice && (
              <>
                <span class="text-xl text-slate-400 line-through">{product.originalPrice}</span>
                {(() => {
                  const current = parseFloat(product.price.replace(/[^0-9.]/g, ''));
                  const original = parseFloat(product.originalPrice.replace(/[^0-9.]/g, ''));
                  const off = Math.round((1 - current / original) * 100);
                  return <span class="text-sm font-semibold text-green-600 dark:text-green-400">{off}% off</span>;
                })()}
              </>
            )}
          </div>

          {product.description && (
            <div class="mb-8">
              <h2 class="font-heading text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg>
                About this item
              </h2>
              <ul class="space-y-3">
                {product.description.split(/\r?\n/).filter(Boolean).map(line => (
                  <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                    <svg class="w-4 h-4 mt-0.5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                    <span>{line.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {chartPoints.length > 1 && (
            <div class="mb-8">
              <h2 class="font-heading text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
                Price History
              </h2>
              <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-4 sm:p-6">
                <svg viewBox="0 0 600 200" class="w-full h-48" preserveAspectRatio="xMidYMid meet">
                  <text x="8" y="16" class="text-xs fill-slate-400" font-size="11">{chartMax.toLocaleString('en-IN')}</text>
                  <text x="8" y="192" class="text-xs fill-slate-400" font-size="11">{chartMin.toLocaleString('en-IN')}</text>
                  <polyline points={chartPoints.map(p => `${p.x},${p.y}`).join(' ')} fill="none" stroke="#6366f1" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
                  {chartPoints.map(p => (
                    <circle cx={p.x} cy={p.y} r="3" fill="#6366f1"><title>₹{p.price.toLocaleString('en-IN')} ({p.date})</title></circle>
                  ))}
                  {chartDateLabels.map((label, i) => label ? (
                    <text x={chartPoints[i].x} y="195" class="text-xs fill-slate-400" font-size="10" text-anchor="middle">{label}</text>
                  ) : null)}
                </svg>
              </div>
            </div>
          )}

          {isAdmin && (
            <button id="check-price-btn" data-product-id={id}
              class="mb-6 inline-flex items-center gap-2 px-4 py-2 bg-amber-500 text-white rounded-xl text-sm font-medium hover:bg-amber-600 transition-colors"
            >Check Price on Amazon</button>
          )}

          {product.affiliateUrl ? (
            <>
              <a
                href={product.affiliateUrl}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="inline-flex items-center justify-center gap-3 w-full sm:w-auto px-8 py-4 bg-primary-600 text-white rounded-xl text-lg font-semibold hover:bg-primary-700 transition-all shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Check out Here
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
              </a>
              <p class="mt-3 text-xs text-slate-400">You will be redirected to Amazon.in to complete your purchase. As an affiliate, we may earn a commission.</p>
            </>
          ) : (
            <p class="text-sm text-slate-500 dark:text-slate-400 italic">Affiliate link not yet available. Check back later.</p>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ productId: id }}>
  const btn = document.getElementById('check-price-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      btn.innerHTML = '<svg class="animate-spin w-4 h-4" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Checking...';
      try {
        const res = await fetch('/api/check-price/' + productId, { method: 'POST' });
        const data = await res.json();
        if (data.price) {
          btn.textContent = '✓ Price Updated!';
          setTimeout(() => location.reload(), 1500);
        } else if (data.notice) {
          btn.textContent = data.error || 'Failed';
          btn.title = data.notice;
          setTimeout(() => { btn.disabled = false; btn.innerHTML = 'Check Price on Amazon'; }, 4000);
        } else {
          btn.textContent = data.error || 'Failed to check price';
          setTimeout(() => { btn.disabled = false; btn.innerHTML = 'Check Price on Amazon'; }, 3000);
        }
      } catch {
        btn.textContent = 'Network error';
        setTimeout(() => { btn.disabled = false; btn.innerHTML = 'Check Price on Amazon'; }, 3000);
      }
    });
  }
</script>
