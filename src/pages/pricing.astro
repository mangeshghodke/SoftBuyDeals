---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingComponent from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
---

<BaseLayout title="Pricing" description="Simple and transparent pricing for Zenix.">
  <div class="bg-slate-50 dark:bg-[#0c0c0f] border-b border-slate-200 dark:border-slate-800 py-16 md:py-24 transition-colors">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">Pricing Plans</h1>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        Choose the perfect plan for your next big project.
      </p>
    </div>
  </div>

  <PricingComponent />
  <FAQ />
  
</BaseLayout>
