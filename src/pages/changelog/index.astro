---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';

const entries = await getCollection('changelog');

// Sort entries by date descending
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Changelog" description="See what's new in Zenix.">
  <div class="bg-slate-50 dark:bg-[#0c0c0f] border-b border-slate-200 dark:border-slate-800 py-16 md:py-24 transition-colors">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">Changelog</h1>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        New updates, features, and improvements.
      </p>
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 max-w-3xl">
    <div class="relative border-l-2 border-slate-200 dark:border-slate-800 ml-3 md:ml-0 md:pl-0">
      {entries.map(async (entry) => {
        const { Content } = await render(entry);
        return (
          <div class="mb-16 relative md:ml-8 pl-8 md:pl-0">
            {/* Timeline Dot */}
            <div class="absolute w-6 h-6 bg-primary-100 dark:bg-primary-900/40 border-4 border-white dark:border-[#09090b] rounded-full -left-[1.95rem] md:-left-11 top-1.5 shadow-sm"></div>
            
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 mb-4">
              <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{entry.data.version}</h2>
              <div class="flex items-center gap-3">
                <Badge variant={entry.data.type === 'major' ? 'primary' : entry.data.type === 'minor' ? 'success' : 'neutral'}>
                  {entry.data.type}
                </Badge>
                <time datetime={entry.data.date.toISOString()} class="text-sm text-slate-500 dark:text-slate-400">
                  {entry.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
            </div>
            
            <h3 class="text-lg font-medium text-slate-800 dark:text-slate-200 mb-4">{entry.data.title}</h3>
            
            <div class="prose prose-slate dark:prose-invert max-w-none prose-a:text-primary-600 dark:prose-a:text-primary-400 hover:prose-a:text-primary-500 bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
              <Content />
            </div>
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>
