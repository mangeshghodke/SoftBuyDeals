---
import BaseLayout from '../layouts/BaseLayout.astro';

const sent = Astro.url.searchParams.get('sent');
---

<BaseLayout title="Contact Us" description="Get in touch with SoftBuyDeals. We'd love to hear from you.">
  <div class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">Contact Us</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-10">Have a question, suggestion, or feedback? We'd love to hear from you.</p>

      {sent && (
        <div class="mb-8 p-4 bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 rounded-xl text-green-700 dark:text-green-300 text-sm">
          Message sent! We'll get back to you within 24 hours.
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="glass-panel rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
            <h3 class="font-semibold text-slate-900 dark:text-white">Email</h3>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            <a href="mailto:support@softbuydeals.com" class="text-primary-600 dark:text-primary-400 hover:underline">support@softbuydeals.com</a>
          </p>
        </div>

        <div class="glass-panel rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
            <h3 class="font-semibold text-slate-900 dark:text-white">Phone</h3>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            <a href="tel:+919876543210" class="text-primary-600 dark:text-primary-400 hover:underline">+91 98765 43210</a>
          </p>
        </div>
      </div>

      <form id="contact-form" action="/api/contact/" method="POST" class="glass-panel rounded-2xl p-6 sm:p-8 space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Name</label>
            <input id="name" name="name" type="text" required
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
            <input id="email" name="email" type="email" required
              class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white"
              placeholder="you@example.com"
            />
          </div>
        </div>
        <div>
          <label for="message" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Message</label>
          <textarea id="message" name="message" rows="5" required
            class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white resize-none"
            placeholder="Your message..."
          ></textarea>
        </div>
        <button type="submit" id="submit-btn"
          class="px-6 py-3 bg-primary-600 text-white rounded-xl text-sm font-medium hover:bg-primary-700 transition-colors disabled:opacity-50"
        >Send Message</button>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form');
  const btn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();

      if (res.ok && !data.error) {
        btn.textContent = 'Sent!';
        btn.className = 'px-6 py-3 bg-green-600 text-white rounded-xl text-sm font-medium cursor-default';
        setTimeout(() => window.location.href = '/contact/?sent=1', 2000);
      } else {
        btn.textContent = 'Try Again';
        btn.disabled = false;
        btn.className = 'px-6 py-3 bg-primary-600 text-white rounded-xl text-sm font-medium hover:bg-primary-700 transition-colors';
        alert(data.error || data.message || 'Failed to send. Please try again.');
      }
    } catch {
      btn.textContent = 'Try Again';
      btn.disabled = false;
      btn.className = 'px-6 py-3 bg-primary-600 text-white rounded-xl text-sm font-medium hover:bg-primary-700 transition-colors';
      alert('Network error. Please try again.');
    }
  });
</script>
