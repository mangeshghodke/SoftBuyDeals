---
const faqs = [
  {
    question: "Do I need to know Astro to use Zenix?",
    answer: "Basic knowledge of HTML and Tailwind CSS is helpful, but you don't need to be an Astro expert. The code is well-commented and structured to be intuitive even for beginners."
  },
  {
    question: "Can I use this for client projects?",
    answer: "Yes. Zenix is released under the MIT license, so you can use it for personal, commercial, and client projects."
  },
  {
    question: "Does it work with standard Markdown?",
    answer: "Yes, the blog supports both standard Markdown (.md) and MDX (.mdx) files, allowing you to embed interactive components directly in your posts."
  },
  {
    question: "How do I deploy it?",
    answer: "Since it's built with Astro, you can deploy it anywhere that hosts static sites: Vercel, Netlify, Cloudflare Pages, GitHub Pages, or your own server."
  },
  {
    question: "Can I customize the design?",
    answer: "Yes. Branding, navigation, social links, and common site settings live in src/config.ts, while sections and components can be edited directly."
  }
];
---

<section class="py-32 bg-white dark:bg-[#09090b] relative overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl relative z-10">
    <div class="text-center mb-16 reveal-on-scroll">
      <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-slate-900 dark:text-white mb-6">Frequently Asked Questions</h2>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        Everything you need to know about Zenix.
      </p>
    </div>

    <div class="space-y-4">
      {faqs.map((faq, index) => (
        <details class="group glass-panel rounded-2xl [&_summary::-webkit-details-marker]:hidden reveal-on-scroll" style={`transition-delay: ${index * 50}ms;`}>
          <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-6 text-slate-900 dark:text-white font-medium">
            <h3 class="text-lg font-heading font-bold">{faq.question}</h3>
            <span class="relative h-5 w-5 shrink-0 text-slate-500 dark:text-slate-400 group-open:text-primary-600 dark:group-open:text-primary-400 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-slate-600 dark:text-slate-400 leading-relaxed">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
