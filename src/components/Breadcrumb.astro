---
export interface Crumb {
  label: string;
  url?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400">
    <li>
      <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-slate-300 dark:text-slate-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path d="m9 18 6-6-6-6"/></svg>
        {item.url ? (
          <a href={item.url} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{item.label}</a>
        ) : (
          <span class="text-slate-900 dark:text-white font-medium truncate max-w-[200px] sm:max-w-xs" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.url).href },
    ...items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: item.label,
      ...(item.url ? { item: new URL(item.url, Astro.url).href } : {}),
    })),
  ],
})} />
