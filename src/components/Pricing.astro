---
import Button from './Button.astro';
import Badge from './Badge.astro';
---

<section id="pricing" class="py-32 bg-slate-50 dark:bg-[#0c0c0f] border-t border-slate-200 dark:border-slate-800">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
      <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-slate-900 dark:text-white mb-6">Simple, transparent pricing</h2>
      <p class="text-xl text-slate-600 dark:text-slate-400 mb-10">
        No hidden fees. No surprise charges. Just choose the plan that works best for you.
      </p>

      <!-- Toggle -->
      <div class="flex items-center justify-center gap-4 p-2 inline-flex bg-white dark:bg-slate-900 rounded-full border border-slate-200 dark:border-slate-800 shadow-sm mx-auto">
        <span class="text-sm font-bold text-slate-900 dark:text-white px-4" id="monthly-label">Monthly</span>
        <button type="button" id="pricing-toggle" class="relative inline-flex h-7 w-12 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-slate-200 dark:bg-slate-700 transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary-600 focus:ring-offset-2 dark:focus:ring-offset-slate-900" role="switch" aria-checked="false">
          <span class="sr-only">Use setting</span>
          <span aria-hidden="true" class="pointer-events-none inline-block h-6 w-6 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out translate-x-0" id="toggle-thumb"></span>
        </button>
        <span class="text-sm font-medium text-slate-500 dark:text-slate-400 px-4" id="annual-label">
          Annually <span class="text-xs text-green-600 dark:text-green-400 font-bold ml-1 bg-green-100 dark:bg-green-900/30 px-2 py-0.5 rounded-full">Save 20%</span>
        </span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <!-- Starter Plan -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col reveal-on-scroll">
        <h3 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-2">Starter</h3>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-8">Perfect for side projects and indie hackers.</p>
        <div class="mb-8">
          <span class="text-5xl font-heading font-extrabold text-slate-900 dark:text-white" data-monthly="$19" data-annual="$15">$19</span>
          <span class="text-slate-500 dark:text-slate-400 font-medium">/mo</span>
        </div>
        <Button variant="outline" class="w-full mb-8">Get Started</Button>
        <ul class="space-y-4 text-sm text-slate-600 dark:text-slate-300 flex-grow">
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Up to 1,000 users</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Basic analytics</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Community support</li>
        </ul>
      </div>

      <!-- Pro Plan -->
      <div class="glass-panel border-2 border-primary-500 dark:border-primary-500 rounded-3xl p-8 flex flex-col relative transform lg:-translate-y-4 shadow-2xl shadow-primary-500/10 reveal-on-scroll" style="transition-delay: 100ms;">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <Badge variant="primary" class="px-4 py-1.5 font-bold shadow-sm">Most Popular</Badge>
        </div>
        <h3 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-2 mt-2">Pro</h3>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-8">For growing startups that need more power.</p>
        <div class="mb-8">
          <span class="text-5xl font-heading font-extrabold text-slate-900 dark:text-white" data-monthly="$49" data-annual="$39">$49</span>
          <span class="text-slate-500 dark:text-slate-400 font-medium">/mo</span>
        </div>
        <Button variant="primary" class="w-full mb-8">Get Started</Button>
        <ul class="space-y-4 text-sm text-slate-600 dark:text-slate-300 flex-grow">
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Up to 10,000 users</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Advanced analytics</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Priority email support</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Custom domain</li>
        </ul>
      </div>

      <!-- Enterprise Plan -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col reveal-on-scroll" style="transition-delay: 200ms;">
        <h3 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-2">Enterprise</h3>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-8">Custom solutions for large scale operations.</p>
        <div class="mb-8">
          <span class="text-5xl font-heading font-extrabold text-slate-900 dark:text-white" data-monthly="$99" data-annual="$79">$99</span>
          <span class="text-slate-500 dark:text-slate-400 font-medium">/mo</span>
        </div>
        <Button variant="outline" class="w-full mb-8">Contact Sales</Button>
        <ul class="space-y-4 text-sm text-slate-600 dark:text-slate-300 flex-grow">
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Unlimited users</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Custom reporting</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> 24/7 phone support</li>
          <li class="flex gap-3"><svg class="h-5 w-5 text-primary-500 dark:text-primary-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> SLA Guarantee</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  function setupPricingToggle() {
    const toggle = document.getElementById('pricing-toggle');
    const thumb = document.getElementById('toggle-thumb');
    const monthlyLabel = document.getElementById('monthly-label');
    const annualLabel = document.getElementById('annual-label');
    const prices = document.querySelectorAll('[data-monthly]');

    let isAnnual = false;

    if (toggle && thumb && monthlyLabel && annualLabel) {
      // Clean up previous event listeners by cloning
      const newToggle = toggle.cloneNode(true);
      toggle.parentNode?.replaceChild(newToggle, toggle);

      newToggle.addEventListener('click', () => {
        isAnnual = !isAnnual;
        
        // Use a consistent way to update elements
        if (isAnnual) {
          newToggle.classList.remove('bg-slate-200', 'dark:bg-slate-700');
          newToggle.classList.add('bg-primary-600');
          
          const thumbEl = newToggle.querySelector('#toggle-thumb');
          thumbEl?.classList.remove('translate-x-0');
          thumbEl?.classList.add('translate-x-5');

          monthlyLabel.classList.remove('font-bold', 'text-slate-900', 'dark:text-white');
          monthlyLabel.classList.add('font-medium', 'text-slate-500', 'dark:text-slate-400');
          
          annualLabel.classList.remove('font-medium', 'text-slate-50', 'dark:text-slate-400');
          annualLabel.classList.add('font-bold', 'text-slate-900', 'dark:text-white');
        } else {
          newToggle.classList.remove('bg-primary-600');
          newToggle.classList.add('bg-slate-200', 'dark:bg-slate-700');
          
          const thumbEl = newToggle.querySelector('#toggle-thumb');
          thumbEl?.classList.remove('translate-x-5');
          thumbEl?.classList.add('translate-x-0');

          monthlyLabel.classList.remove('font-medium', 'text-slate-500', 'dark:text-slate-400');
          monthlyLabel.classList.add('font-bold', 'text-slate-900', 'dark:text-white');
          
          annualLabel.classList.remove('font-bold', 'text-slate-900', 'dark:text-white');
          annualLabel.classList.add('font-medium', 'text-slate-500', 'dark:text-slate-400');
        }

        prices.forEach(priceEl => {
          const value = isAnnual ? priceEl.getAttribute('data-annual') : priceEl.getAttribute('data-monthly');
          if (value) priceEl.textContent = value;
        });
      });
    }
  }

  // Initial load
  setupPricingToggle();
  // View transitions
  document.addEventListener('astro:page-load', setupPricingToggle);
</script>