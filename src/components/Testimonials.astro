---
import { Image } from 'astro:assets';

const testimonials = [
  {
    quote: "Zenix saved me weeks of development time. I was able to focus entirely on my product's core features instead of tweaking landing page CSS.",
    author: "David Morgan",
    role: "Founder, DataFlow",
    avatar: "https://i.pravatar.cc/150?u=david"
  },
  {
    quote: "The cleanest Astro theme I've used. The code is structured beautifully, and the Lighthouse scores are genuinely 100 straight out of the box.",
    author: "Marcus Chen",
    role: "Indie Hacker",
    avatar: "https://i.pravatar.cc/150?u=marcus"
  },
  {
    quote: "Converted my old React landing page to Zenix in a day. The bundle size dropped by 90% and my conversion rate went up by 15%. Highly recommend.",
    author: "Elena Rodriguez",
    role: "CEO, Streamline",
    avatar: "https://i.pravatar.cc/150?u=elena"
  }
];
---

<section id="testimonials" class="py-32 bg-white dark:bg-[#09090b] relative overflow-hidden">
  
  <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/3 w-[500px] h-[500px] bg-primary-500/10 dark:bg-primary-500/5 rounded-full blur-[100px] mix-blend-multiply dark:mix-blend-screen pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 reveal-on-scroll">
      <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-slate-900 dark:text-white mb-6">Loved by Founders</h2>
      <p class="text-xl text-slate-600 dark:text-slate-400">
        Don't just take our word for it. See what others are building with Zenix.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {testimonials.map((t, index) => (
        <div class="glass-panel p-8 rounded-3xl flex flex-col h-full hover-glow reveal-on-scroll relative group" style={`transition-delay: ${index * 100}ms;`}>
          <!-- Decorative quotation mark -->
          <div class="absolute top-6 right-6 text-6xl text-slate-100 dark:text-slate-800/50 font-serif leading-none transform transition-transform group-hover:scale-110 group-hover:-rotate-12 duration-500">"</div>
          
          <!-- Rating stars -->
          <div class="flex gap-1 text-accent-500 dark:text-accent-400 mb-6 relative z-10">
            {[1, 2, 3, 4, 5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          
          <blockquote class="text-slate-700 dark:text-slate-300 text-lg mb-8 flex-grow relative z-10 font-medium leading-relaxed">
            "{t.quote}"
          </blockquote>
          
          <div class="flex items-center gap-4 relative z-10">
            <Image src={t.avatar} alt={`Portrait of ${t.author}`} width={48} height={48} class="w-12 h-12 rounded-full border-2 border-slate-100 dark:border-slate-800 shadow-sm" loading="lazy" />
            <div>
              <div class="font-bold text-slate-900 dark:text-white">{t.author}</div>
              <div class="text-sm text-slate-500 dark:text-slate-400">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
