---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Filter out h1 and filter depths to only show h2 and h3
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
---

{toc.length > 0 && (
  <nav class="sticky top-24 self-start hidden lg:block max-w-xs">
    <h3 class="text-sm font-bold font-heading text-slate-900 dark:text-white uppercase tracking-wider mb-4">On this page</h3>
    <ul class="space-y-2 text-sm border-l-2 border-slate-200 dark:border-slate-800">
      {toc.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class={`block py-1 pl-4 -ml-[2px] border-l-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors
              ${heading.depth === 3 ? 'ml-2 text-xs' : ''}
            `}
            data-toc-link
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  function setupTocHighlighting() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute('id');
          if (!id) return;
          
          const link = document.querySelector(`nav a[href="#${id}"]`);
          if (!link) return;

          if (entry.isIntersecting) {
            // Remove active class from all links
            document.querySelectorAll('nav a[data-toc-link]').forEach((a) => {
              a.classList.remove('border-primary-500', 'text-primary-600', 'dark:text-primary-400');
              a.classList.add('border-transparent');
            });
            // Add active class to current intersecting link
            link.classList.remove('border-transparent');
            link.classList.add('border-primary-500', 'text-primary-600', 'dark:text-primary-400');
          }
        });
      },
      { rootMargin: '-10% 0px -80% 0px' } // Adjust margins so it triggers near the top
    );

    // Observe all headings
    document.querySelectorAll('article h2, article h3').forEach((heading) => {
      observer.observe(heading);
    });
  }

  document.addEventListener('astro:page-load', setupTocHighlighting);
</script>
