---
interface Props {
  type?: 'info' | 'warning' | 'danger' | 'success';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config = {
  info: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>`,
    classes: 'bg-blue-50/50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800 text-blue-800 dark:text-blue-300',
    iconColor: 'text-blue-600 dark:text-blue-400'
  },
  warning: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>`,
    classes: 'bg-amber-50/50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-300',
    iconColor: 'text-amber-600 dark:text-amber-400'
  },
  danger: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`,
    classes: 'bg-red-50/50 dark:bg-red-900/20 border-red-200 dark:border-red-800 text-red-800 dark:text-red-300',
    iconColor: 'text-red-600 dark:text-red-400'
  },
  success: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`,
    classes: 'bg-green-50/50 dark:bg-green-900/20 border-green-200 dark:border-green-800 text-green-800 dark:text-green-300',
    iconColor: 'text-green-600 dark:text-green-400'
  }
};

const activeConfig = config[type];
---

<div class={`not-prose mx-auto my-10 w-full max-w-2xl px-6 py-6 border rounded-2xl flex items-start gap-4 shadow-sm ${activeConfig.classes}`}>
  <div class={`mt-1 flex-shrink-0 ${activeConfig.iconColor}`} set:html={activeConfig.icon} />
  <div class="min-w-0">
    {title && <h4 class="font-bold font-heading m-0 mb-2 leading-snug">{title}</h4>}
    <div class="[&>p]:m-0 text-sm leading-6 opacity-90">
      <slot />
    </div>
  </div>
</div>
