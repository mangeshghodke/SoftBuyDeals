---
---

<section id="features" class="py-32 bg-slate-50 dark:bg-[#0c0c0f] border-y border-slate-200 dark:border-slate-800 relative overflow-hidden">
  <!-- Subtle dark background glow -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-slate-200/50 via-transparent to-transparent dark:from-primary-900/10 dark:via-transparent dark:to-transparent"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 reveal-on-scroll">
      <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-slate-900 dark:text-white mb-6">
        Everything you need, <br/><span class="text-slate-400 dark:text-slate-500">nothing you don't.</span>
      </h2>
      <p class="text-xl text-slate-600 dark:text-slate-400 font-sans">
        Ditch the bloat. Zenix gives you a powerful, composable foundation that scales from MVP to Enterprise.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 lg:grid-rows-[minmax(260px,auto)_minmax(280px,auto)] gap-6 max-w-7xl mx-auto">
      
      <!-- Feature 1: Large Span 2x2 -->
      <div class="md:col-span-2 lg:row-span-2 glass-panel rounded-3xl p-8 flex flex-col hover-glow reveal-on-scroll relative overflow-hidden group min-h-[420px] lg:min-h-0">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 bg-primary-100 dark:bg-primary-900/40 text-primary-600 dark:text-primary-400 rounded-2xl flex items-center justify-center mb-6 shadow-inner" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>`} />
        <h3 class="text-3xl font-heading font-bold text-slate-900 dark:text-white mb-4 z-10">Blazing Fast Astro Architecture</h3>
        <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-8 flex-grow z-10">
          Built on Astro's islands architecture, Zenix ships zero JavaScript by default. Achieve perfect 100/100 Lighthouse scores without breaking a sweat, ensuring your visitors never wait.
        </p>
        
        <!-- Decorative Code Block inside the Bento Box -->
        <div class="bg-slate-900 dark:bg-[#111116] rounded-xl p-4 font-mono text-sm text-primary-300 shadow-2xl border border-slate-700 dark:border-slate-800 z-10 transform transition-transform group-hover:-translate-y-2 duration-500">
          <div class="flex gap-2 mb-3">
             <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
             <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
          </div>
          <code>git clone https://github.com/farrosfr/zenix.git</code>
        </div>
      </div>

      <!-- Feature 2: Standard Span -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col hover-glow reveal-on-scroll min-h-[320px] lg:min-h-0" style="transition-delay: 100ms;">
        <div class="w-12 h-12 bg-accent-100 dark:bg-accent-900/40 text-accent-600 dark:text-accent-400 rounded-2xl flex items-center justify-center mb-6" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>`} />
        <h3 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-3">Conversion Optimized</h3>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
          Designed using proven SaaS landing page heuristics. Every button, gradient, and layout choice is engineered to convert visitors.
        </p>
      </div>

      <!-- Feature 3: Standard Span -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col hover-glow reveal-on-scroll min-h-[320px] lg:min-h-0" style="transition-delay: 200ms;">
        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 rounded-2xl flex items-center justify-center mb-6" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>`} />
        <h3 class="text-xl font-heading font-bold text-slate-900 dark:text-white mb-3">Tailwind v4 Native</h3>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
          Built with the latest version of Tailwind CSS. Customize the entire theme's typography and color palette from a single config file.
        </p>
      </div>

      <!-- Feature 4: Horizontal Span -->
      <div class="md:col-span-2 lg:col-start-3 lg:row-start-2 glass-panel rounded-3xl p-8 flex flex-col sm:flex-row items-center gap-8 hover-glow reveal-on-scroll min-h-[280px] lg:min-h-0" style="transition-delay: 300ms;">
        <div class="flex-grow">
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 rounded-2xl flex items-center justify-center mb-6" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>`} />
          <h3 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-3">Powerful MDX Content Engine</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Write your blog posts and changelogs in Markdown or MDX. Render complex interactive components directly inside your written content with full Astro Content Collection type-safety.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
