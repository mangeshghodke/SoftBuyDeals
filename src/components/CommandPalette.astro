---
import { resolvePath } from '../utils/navigation';
---

<div
  id="command-palette"
  class="fixed inset-0 z-[100] hidden isolate overflow-y-auto p-4 sm:p-6 md:p-20"
  role="dialog"
  aria-modal="true"
>
  <div data-command-backdrop class="fixed inset-0 z-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-2xl transform divide-y divide-slate-100 dark:divide-slate-800 overflow-hidden rounded-2xl bg-white dark:bg-slate-900 shadow-2xl ring-1 ring-slate-900/5 transition-all">
    <div class="relative">
      <svg
        class="pointer-events-none absolute left-4 top-3.5 h-5 w-5 text-slate-400"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z"
          clip-rule="evenodd"></path>
      </svg>
      <input
        type="text"
        id="search-input"
        class="h-12 w-full border-0 bg-transparent pl-11 pr-4 text-slate-900 dark:text-white placeholder:text-slate-400 focus:ring-0 sm:text-sm"
        placeholder="Search products..."
        role="combobox"
        aria-expanded="false"
        aria-controls="options"
      />
    </div>

    <ul
      class="max-h-96 scroll-py-3 overflow-y-auto p-3 hidden"
      id="search-results"
      role="listbox"
    >
    </ul>

    <div id="search-help" class="px-6 py-14 text-center sm:px-14">
      <svg
        class="mx-auto h-6 w-6 text-slate-400"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
      </svg>
      <p class="mt-4 text-sm text-slate-900 dark:text-white font-medium">Search products & content</p>
      <p class="mt-2 text-sm text-slate-500">Type to search for products.</p>
    </div>
  </div>
</div>

<script is:inline define:vars={{ resolvePath: resolvePath('/') }}>
  function setupSearch() {
    const palette = document.getElementById('command-palette');
    const input = document.getElementById('search-input');
    const resultsList = document.getElementById('search-results');
    const helpState = document.getElementById('search-help');
    const backdrop = palette?.querySelector('[data-command-backdrop]');

    if (!palette || !input || !resultsList || !helpState) return;
    
    window.__searchIndex = window.__searchIndex || [];
    window.__searchLoaded = window.__searchLoaded || false;

    async function loadIndex() {
      if (window.__searchLoaded) return;
      try {
        const response = await fetch(`${resolvePath}search-index.json`);
        window.__searchIndex = await response.json();
        window.__searchLoaded = true;

        const query = input.value.toLowerCase().trim();
        if (query) {
          renderResults(getMatches(query));
        }
      } catch (err) {
        console.error('Failed to load search index:', err);
      }
    }

    function getMatches(query) {
      return window.__searchIndex.filter(item => 
        item.title.toLowerCase().includes(query) || 
        (item.description && item.description.toLowerCase().includes(query))
      );
    }

    function togglePalette() {
      const isHidden = palette.classList.contains('hidden');
      if (isHidden) {
        palette.classList.remove('hidden');
        loadIndex();
        input.focus();
        document.body.style.overflow = 'hidden';
      } else {
        palette.classList.add('hidden');
        document.body.style.overflow = '';
      }
    }

    window.toggleCommandPalette = togglePalette;

    if (!window.__searchKeyBound) {
      window.__searchKeyBound = true;
      window.addEventListener('keydown', (e) => {
        const activePalette = document.getElementById('command-palette');
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          window.toggleCommandPalette?.();
        }
        
        if (e.key === 'Escape' && activePalette && !activePalette.classList.contains('hidden')) {
          window.toggleCommandPalette?.();
        }
      });
    }

    if (palette.dataset.searchBound === 'true') return;
    palette.dataset.searchBound = 'true';

    palette.addEventListener('click', (e) => {
      if (e.target === palette || e.target === backdrop) {
        togglePalette();
      }
    });

    input.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      if (!query) {
        resultsList.classList.add('hidden');
        helpState.classList.remove('hidden');
        return;
      }

      renderResults(getMatches(query));
    });

    function renderResults(matches) {
      helpState.classList.add('hidden');
      resultsList.classList.remove('hidden');
      resultsList.innerHTML = '';

      if (matches.length === 0) {
        const li = document.createElement('li');
        li.className = 'px-4 py-14 text-center sm:px-14';
        const p = document.createElement('p');
        p.className = 'text-sm text-slate-500';
        p.textContent = 'No results found for that query.';
        li.appendChild(p);
        resultsList.appendChild(li);
        return;
      }

      for (const item of matches) {
        const href = item.url || `${resolvePath}${item.slug.startsWith('/') ? item.slug.slice(1) : item.slug}`;
        const icon = item.type === 'Product' ? 'P' : item.type.charAt(0);

        const li = document.createElement('li');
        li.className = 'group cursor-pointer select-none rounded-xl p-3 hover:bg-primary-600 dark:hover:bg-primary-500 transition-colors';
        li.setAttribute('role', 'option');
        li.tabIndex = -1;
        li.dataset.href = href;

        const a = document.createElement('a');
        a.href = href;
        a.className = 'flex items-center';

        const iconDiv = document.createElement('div');
        iconDiv.className = 'flex h-10 w-10 flex-none items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 group-hover:bg-white/20 overflow-hidden';

        if (item.image && item.type === 'Product') {
          const img = document.createElement('img');
          img.src = item.image;
          img.alt = '';
          img.className = 'w-full h-full object-contain p-1';
          iconDiv.appendChild(img);
        } else {
          const span = document.createElement('span');
          span.className = 'text-xs font-bold text-slate-500 dark:text-slate-400 group-hover:text-white uppercase';
          span.textContent = icon;
          iconDiv.appendChild(span);
        }
        a.appendChild(iconDiv);

        const textDiv = document.createElement('div');
        textDiv.className = 'ml-4 flex-auto min-w-0';

        const titleP = document.createElement('p');
        titleP.className = 'text-sm font-medium text-slate-900 dark:text-white group-hover:text-white truncate';
        titleP.textContent = item.title;
        textDiv.appendChild(titleP);

        const descP = document.createElement('p');
        descP.className = 'text-xs text-slate-500 dark:text-slate-400 group-hover:text-primary-100 line-clamp-1';
        if (item.type === 'Product') {
          descP.textContent = (item.category ? `[${item.category}] ` : '') + (item.description || '');
        } else {
          descP.textContent = item.description || '';
        }
        textDiv.appendChild(descP);
        a.appendChild(textDiv);

        if (item.type === 'Product') {
          const svgSpan = document.createElement('span');
          svgSpan.innerHTML = '<svg class="ml-2 w-4 h-4 flex-shrink-0 text-slate-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>';
          a.appendChild(svgSpan);
        }

        li.appendChild(a);
        resultsList.appendChild(li);
      }
    }
  }

  setupSearch();
  document.addEventListener('astro:page-load', setupSearch);
</script>
